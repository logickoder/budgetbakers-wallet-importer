{
  "name": "budgetbakers-wallet-importer",
  "version": "1.0.0",
  "description": "Direct CouchDB importer for BudgetBakers / Wallet app CSV exports",
  "type": "module",
  "bin": {
    "budgetbakers-wallet-importer": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "api.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "build": "tsc",
    "run:built": "node dist/cli/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "prepack": "pnpm test && pnpm build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "axios-cookiejar-support": "^5.0.5",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.7.0",
    "luxon": "^3.7.2",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.19.37",
    "@types/qs": "^6.15.0",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}